{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.protean.sh/schemas/public-research-manifest.v1.json",
  "title": "Protean public research manifest",
  "description": "Schema for indexes/latest.json and the per-line entries of indexes/manifest.jsonl.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "protean.public-research-manifest.v1"
    },
    "generated_at": { "type": "string" },
    "manifest_hash": {
      "type": "string",
      "description": "sha256 over (path, content_hash) of every artifact. Changes only when artifact content changes.",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "artifact_count": { "type": "integer", "minimum": 0 },
    "latest_by_kind": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/manifestEntry" }
    }
  },
  "required": ["schema_version"],
  "$defs": {
    "manifestEntry": {
      "type": "object",
      "required": ["kind", "slug", "title", "path", "content_hash"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "path": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "generated_at": { "type": ["string", "null"] },
        "content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    }
  }
}
